# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/dila?retryWrites=true&w=majority

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
INITIAL_BALANCE=500

# ── Security ──────────────────────────────────────────────────────────────────
# Must match the X-Api-Key header sent by the Cloudflare Worker
WEBHOOK_SECRET=your-secret-key-here
